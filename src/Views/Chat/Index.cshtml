@{
    ViewData["Title"] = "Chat with Phi-4";
}

<div class="container mt-4">
    <h1 class="mb-4">Chat with Phi-4</h1>
    <p class="text-muted">Powered by Microsoft Azure AI Foundry. Type a message and press <strong>Send</strong> to start a conversation.</p>

    <div class="row">
        <div class="col-md-8 offset-md-2">
            @if (!string.IsNullOrEmpty(ViewBag.ErrorMessage))
            {
                <div class="alert alert-danger" role="alert">
                    <i class="bi bi-exclamation-triangle me-2"></i>@ViewBag.ErrorMessage
                </div>
            }

            <div class="mb-3">
                <label for="conversationDisplay" class="form-label fw-semibold">Conversation</label>
                <textarea id="conversationDisplay"
                          class="form-control font-monospace"
                          rows="12"
                          readonly>@ViewBag.ConversationDisplay</textarea>
            </div>

            <form asp-controller="Chat" asp-action="SendMessage" method="post">
                <div class="mb-3">
                    <label for="userMessage" class="form-label fw-semibold">Your message</label>
                    <input type="text"
                           id="userMessage"
                           name="userMessage"
                           class="form-control"
                           placeholder="Type your message here..."
                           autocomplete="off"
                           required />
                </div>
                <div class="d-flex gap-2">
                    <button type="submit" class="btn btn-primary">
                        <i class="bi bi-send me-1"></i>Send
                    </button>
                </div>
            </form>

            <form asp-controller="Chat" asp-action="Clear" method="post" class="mt-2">
                <button type="submit" class="btn btn-outline-secondary">Clear</button>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Scroll conversation area to the bottom on page load
        (function () {
            var textarea = document.getElementById('conversationDisplay');
            if (textarea) {
                textarea.scrollTop = textarea.scrollHeight;
            }
        })();
    </script>
}
